# Copy this file to .env.local and fill in values from your CDK deployment outputs.
# Run `npm run deploy` from the service/ directory, then check cdk-outputs.json.

# API Gateway URL (from CDK output: ApiUrl)
SITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/

# Cognito (from CDK outputs: AdminUserPoolId, AdminUserPoolClientId)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
